{
  "name": "io-manager-firmware-uploader",
  "version": "0.0.63",
  "private": true,
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.2.0",
    "@mui/lab": "9.0.0-beta.6",
    "@mui/material": "^9.2.0",
    "@wbm-tek/version-manager": "^0.0.82",
    "axios": "^1.18.1",
